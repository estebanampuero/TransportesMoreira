rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de cargas subidas por clientes en el formulario CRM
    match /leads/photos/{fileName} {
      allow write: if request.resource.size < 10 * 1024 * 1024  // máx 10 MB
                   && request.resource.contentType.matches('image/.*');
      allow read: if false; // solo admin vía URL firmada
    }

    // Imágenes públicas del sitio (flota, activos)
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
